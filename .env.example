# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider -------------------------------------------------------------
OPENAI_API_KEY=
# Optional: override API base URL if you use an OpenAI-compatible proxy/router.
OPENAI_BASE_URL=
# Optional: override model IDs.
OPENAI_MODEL_WORKHORSE=gpt-4.1-mini
OPENAI_MODEL_SYNTHESIS=gpt-4.1

# Optional: Apify (Reddit + TikTok scraping). If unset, those sources are skipped.
APIFY_TOKEN=

# Optional: Tavily web search API key (https://tavily.com). 1k/mo on free tier.
# If unset, we fall back to DuckDuckGo HTML scraping (flaky from datacenter IPs).
TAVILY_API_KEY=

# Optional: Gemini API key for the voice interview mode (Gemini Live).
# Without it, voice mode uses the browser Web Speech API fallback.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Reddit (optional; if unset we use the public JSON endpoint with a User-Agent)
REDDIT_USER_AGENT=launchlens/0.1 (by u/your_reddit_username)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
