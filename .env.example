# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (or Anthropic-compatible router / proxy)
ANTHROPIC_API_KEY=
# Optional: override the API base URL. Leave empty to hit api.anthropic.com directly.
# Example — Kyle's LLM router serving GLM via Anthropic protocol:
#   ANTHROPIC_BASE_URL=https://llm.kyle.pub/s/zai-coding
ANTHROPIC_BASE_URL=
# Optional: override model IDs (defaults are GLM). Set these to e.g.
# claude-sonnet-4-6 / claude-opus-4-7 when pointing at api.anthropic.com.
CLAUDE_MODEL_WORKHORSE=
CLAUDE_MODEL_SYNTHESIS=

# Optional: Apify (Reddit + TikTok scraping). If unset, those sources are skipped.
APIFY_TOKEN=

# Optional: Tavily web search API key (https://tavily.com). 1k/mo on free tier.
# If unset, we fall back to DuckDuckGo HTML scraping (flaky from datacenter IPs).
TAVILY_API_KEY=

# Reddit (optional; if unset we use the public JSON endpoint with a User-Agent)
REDDIT_USER_AGENT=launchlens/0.1 (by u/your_reddit_username)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
