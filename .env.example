# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Optional: Apify (for TikTok scraping). If unset, TikTok source is skipped gracefully.
APIFY_TOKEN=

# Reddit (optional; if unset we use the public JSON endpoint with a User-Agent)
REDDIT_USER_AGENT=launchlens/0.1 (by u/your_reddit_username)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
