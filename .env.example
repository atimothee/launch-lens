# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers ------------------------------------------------------------
# Default routing policy: OpenAI first (if configured), fall back to Anthropic.
# Pin one provider by setting AI_PROVIDER=openai or =anthropic.
AI_PROVIDER=

# OpenAI — primary provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_WORKHORSE=
OPENAI_MODEL_SYNTHESIS=

# Anthropic — fallback. Supports routing through an Anthropic-compatible proxy.
# Example (GLM via Kyle's LLM router): ANTHROPIC_BASE_URL=https://llm.kyle.pub/s/zai-coding
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# Model overrides. Defaults are GLM; set to e.g. claude-sonnet-4-6 / claude-opus-4-7
# when pointing at api.anthropic.com directly.
CLAUDE_MODEL_WORKHORSE=
CLAUDE_MODEL_SYNTHESIS=

# Optional: Apify (Reddit + TikTok scraping). If unset, those sources are skipped.
APIFY_TOKEN=

# Optional: Tavily web search API key (https://tavily.com). 1k/mo on free tier.
# If unset, we fall back to DuckDuckGo HTML scraping (flaky from datacenter IPs).
TAVILY_API_KEY=

# Reddit (optional; if unset we use the public JSON endpoint with a User-Agent)
REDDIT_USER_AGENT=launchlens/0.1 (by u/your_reddit_username)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
